# Скопіюй у .env.local (він у .gitignore) і заповни.
# Використовується скриптом `npm run deploy`.

# Той самий токен, що додано у Lightsail .env.local як STATIC_DEPLOY_TOKEN.
STATIC_DEPLOY_TOKEN=

# Slug існуючої StaticPage на metaphysical-way.academy/demo.
# Сторінку треба створити вручну через /demo (whitelist, title, меню) — а потім
# деплой просто перезаписує її htmlContent.
STATIC_DEPLOY_SLUG=

# Опційно — для тесту проти локального dev-сервера.
# STATIC_DEPLOY_BASE=http://localhost:3000
